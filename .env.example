# Queria env example (copy to .env). Never commit real secrets.
#
# ---------------------------------------------------------------------------
# Env-by-binary ownership matrix (Wave 2 P2 / VAL-SHRINK-005)
# AppConfig loads the full set via AppConfig::from_env(); this matrix is who
# *owns* each group at runtime (primary consumer). Edge (Caddy :17674) is not
# a Rust binary and has no QUERIA_* process env.
#
# | Group (env prefixes / keys)              | Primary binary owner              | Also used by                          |
# |------------------------------------------|-----------------------------------|---------------------------------------|
# | Core bind: QUERIA_API_ADDR               | queria-api                        | —                                     |
# | Core bind: QUERIA_MCP_ADDR               | queria-mcp                        | —                                     |
# | Core bind: QUERIA_WORKER_HEALTH_ADDR     | reserved / ops                    | worker does not bind health today     |
# | QUERIA_ENV, QUERIA_LOG_LEVEL             | all server bins                   | queria-api, queria-mcp, queria-worker |
# | QUERIA_DATABASE_URL                      | all that touch Postgres           | api, mcp, worker, cli (ops)           |
# | QUERIA_PUBLIC_BASE_URL                   | queria-api (hooks/setup URLs)     | —                                     |
# | QUERIA_SETUP_TOKEN, FIRST_ADMIN/ORG_*    | queria-api (first-run setup)      | cli embeddings (admin email lookup)   |
# | QUERIA_PLATFORM_SUPER_ADMIN_EMAILS       | queria-api (session elevation)    | optional                              |
# | QUERIA_MAX_BODY_BYTES                    | queria-mcp (index/propose body)   | shared AppConfig default 20_000       |
# | Qdrant: QUERIA_QDRANT_*, QDRANT_API_KEY  | api + mcp (retrieve) + worker     | cli backup restore target             |
# | Embedding: VOYAGE_API_KEY, QUERIA_EMBED* | worker (backfill) + retrieve path | api/mcp via search build              |
# | Retrieval: QUERIA_RETRIEVAL_*, RERANK_*, COMPRESS_* | api + mcp (search)   | —                                     |
# | MinIO: QUERIA_MINIO_*                    | queria-worker (backup jobs)       | queria-cli backup                     |
# | Backup: QUERIA_BACKUP_*                  | queria-worker (cron)              | cli backup ops                        |
# | Git/TruffleHog: QUERIA_GIT_*, TRUFFLEHOG_* | queria-worker only              | —                                     |
# | Worker: QUERIA_WORKER_*                  | queria-worker only                | —                                     |
# | Laptop agent: QUERIA_AGENT_TOKEN, QUERIA_EDGE_URL, QUERIA_PROJECT_SLUG | queria-cli / hooks (not AppConfig) | e2e scripts |
#
# Docs pointer: docs/runbooks/local-development.md (Env-by-binary ownership).
# Full load site: crates/queria-core/src/config.rs (AppConfig::from_env).
# ---------------------------------------------------------------------------

QUERIA_ENV=local
QUERIA_PUBLIC_BASE_URL=http://127.0.0.1:17674
QUERIA_API_ADDR=127.0.0.1:17671
QUERIA_MCP_ADDR=127.0.0.1:17672
QUERIA_WORKER_HEALTH_ADDR=127.0.0.1:17673
# Public edge is Caddy on :17674 (see docker/Caddyfile), not a Rust binary env.
QUERIA_DATABASE_URL=postgres://queria:queria@127.0.0.1:17675/queria
QUERIA_QDRANT_URL=http://127.0.0.1:17676
QDRANT_API_KEY=
QUERIA_QDRANT_COLLECTION=queria_local_chunks_v1
QUERIA_QDRANT_VECTOR_NAME=dense_v1
VOYAGE_API_KEY=
QUERIA_EMBEDDING_MODEL=voyage-4
QUERIA_EMBEDDING_DIMENSION=1024
QUERIA_EMBEDDING_PROFILE_VERSION=voyage-4-1024-v1
QUERIA_EMBEDDING_BATCH_SIZE=64
QUERIA_EMBEDDING_TIMEOUT_SECONDS=30
QUERIA_EMBEDDING_MAX_RETRIES=3
QUERIA_EMBEDDING_REQUEST_INTERVAL_MS=0
QUERIA_EMBEDDING_RETRY_BACKOFF_BASE_SECONDS=30
QUERIA_EMBEDDING_RETRY_BACKOFF_MAX_SECONDS=600
QUERIA_RETRIEVAL_RRF_K=60
QUERIA_RETRIEVAL_CANDIDATE_MULTIPLIER=4
QUERIA_RETRIEVAL_CANDIDATE_CAP=100
# Voyage rerank after hybrid RRF (request may override per call). Default on.
QUERIA_RERANK_ENABLED=true
QUERIA_RERANK_MODEL=rerank-2.5
QUERIA_RERANK_TIMEOUT_SECONDS=30
# Near-duplicate compress after rerank. Prefer trusted over scratch. Default on.
QUERIA_COMPRESS_ENABLED=true
QUERIA_MINIO_ENDPOINT=http://127.0.0.1:17678
QUERIA_MINIO_BUCKET=queria-local
QUERIA_MINIO_ACCESS_KEY=queria
QUERIA_MINIO_SECRET_KEY=queria-local-dev-only
QUERIA_MINIO_REGION=us-east-1
QUERIA_BACKUP_RETENTION_DAYS=30
QUERIA_BACKUP_CRON_HOUR_UTC=2
QUERIA_SOURCE_COMMIT=
QUERIA_SETUP_TOKEN=change-me-one-time-setup-token
QUERIA_FIRST_ADMIN_EMAIL=admin@example.com
QUERIA_FIRST_ORG_SLUG=acme
QUERIA_LOG_LEVEL=info
QUERIA_GIT_ALLOWED_ROOTS=/Users/fernandojulian/project/fjulian/fjulian.me
QUERIA_GIT_ALLOWED_SSH_HOSTS=github.com
QUERIA_GIT_ALLOWED_SSH_REPOSITORIES=nandocoeg2/fjulian.me.git
QUERIA_GIT_EXCLUDED_DIRECTORIES=.git,.astro,.next,node_modules,dist,build,coverage,target
QUERIA_GIT_MAX_FILE_BYTES=1000000
QUERIA_GIT_CHUNK_MAX_LINES=120
QUERIA_GIT_CHUNK_OVERLAP_LINES=20
QUERIA_WORKER_POLL_INTERVAL_MS=2000
QUERIA_WORKER_LEASE_SECONDS=900
QUERIA_WORKER_IDENTITY=queria-git-ingestion
QUERIA_TRUFFLEHOG_EXECUTABLE=trufflehog
QUERIA_TRUFFLEHOG_INCLUDE_PATHS_FILE=config/trufflehog-include-paths.txt
QUERIA_TRUFFLEHOG_EXCLUDE_PATHS_FILE=config/trufflehog-exclude-paths.txt
QUERIA_TRUFFLEHOG_TIMEOUT_SECONDS=300
