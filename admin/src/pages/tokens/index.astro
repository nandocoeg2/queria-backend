---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listAgentTokens, listProjects, fetchFromBackend } from '../../lib/api';

const DAILY_TOOLS = [
  'retrieve_context',
  'search_knowledge',
  'propose_memory',
  'list_projects',
  'get_source',
  'index_memory',
] as const;

const ALL_TOOLS = [
  ...DAILY_TOOLS,
  'index_local',
  'manage_needs_review',
] as const;

let message = '';
let isError = false;
let generatedToken = '';
let generatedTools: string[] = [];
let generatedProjectSlugs: string[] = [];

// Handle generate / revoke token POST
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action');

    if (action === 'generate') {
      const name = (data.get('name')?.toString() || '').trim();
      const selectedSlugs = data
        .getAll('project_slugs')
        .map((v) => v.toString())
        .filter(Boolean);
      const allowGlobal = data.get('allow_global_knowledge') === 'on';
      const expiresIn = data.get('expires_in')?.toString() || 'no_expire';
      const mode = data.get('mode')?.toString() || 'daily';

      let tools: string[];
      if (mode === 'custom') {
        tools = data
          .getAll('tools')
          .map((v) => v.toString())
          .filter((t) => (ALL_TOOLS as readonly string[]).includes(t));
        if (tools.length === 0) {
          message = 'Select at least one tool for Custom mode.';
          isError = true;
        }
      } else {
        tools = [...DAILY_TOOLS];
      }

      if (!isError && !name) {
        message = 'Token name is required.';
        isError = true;
      } else if (!isError && selectedSlugs.length === 0) {
        message = 'Select at least one project.';
        isError = true;
      } else if (!isError) {
        const res = await fetchFromBackend('/api/v1/agent-tokens', Astro.request, {
          method: 'POST',
          body: JSON.stringify({
            name,
            project_slugs: selectedSlugs,
            allow_global_knowledge: allowGlobal,
            expires_in: expiresIn,
            tools,
          }),
        });

        if (res.ok) {
          const result = await res.json();
          generatedToken = result.token;
          generatedTools = Array.isArray(result.agent_token?.tools)
            ? result.agent_token.tools
            : tools;
          generatedProjectSlugs = selectedSlugs;
          message = 'Agent token successfully generated.';
        } else {
          const errorRes = await res.json().catch(() => ({}));
          message = errorRes.error || 'Failed to generate agent token.';
          isError = true;
        }
      }
    } else if (action === 'revoke') {
      const tokenId = data.get('token_id');
      if (tokenId) {
        const res = await fetchFromBackend(`/api/v1/agent-tokens/${tokenId}`, Astro.request, {
          method: 'DELETE',
        });

        if (res.ok) {
          message = 'Agent token successfully revoked.';
        } else {
          const errorRes = await res.json().catch(() => ({}));
          message = errorRes.error || 'Failed to revoke token.';
          isError = true;
        }
      }
    }
  } catch (err) {
    console.error('Agent token action error:', err);
    message = 'Error communicating with server.';
    isError = true;
  }
}

const [tokens, projects] = await Promise.all([
  listAgentTokens(Astro.request),
  listProjects(Astro.request),
]);

if (!tokens || !projects) {
  return Astro.redirect('/admin/login');
}

const hasProjects = Array.isArray(projects) && projects.length > 0;

const publicBase = (
  import.meta.env.QUERIA_PUBLIC_BASE_URL ||
  process.env.QUERIA_PUBLIC_BASE_URL ||
  (() => {
    try {
      const u = new URL(Astro.request.url);
      return `${u.protocol}//${u.hostname}:17674`;
    } catch {
      return 'http://127.0.0.1:17674';
    }
  })()
).replace(/\/$/, '');

// Format dates
const formatDate = (dateStr?: string) => {
  if (!dateStr) return 'Never';
  return new Date(dateStr).toLocaleString('en-US', {
    dateStyle: 'medium',
    timeStyle: 'short',
  });
};
---

<AdminLayout title="Agent Tokens" activeTab="tokens">
  {message && (
    <div class={`alert-message ${isError ? 'error' : 'success'}`}>
      {message}
    </div>
  )}

  {generatedToken && (
    <div class="card token-reveal-box connect-panel">
      <div class="reveal-header">
        <h3>Connect this agent</h3>
        <p class="warning-text">
          This token is shown once. It cannot be recovered after you navigate away or refresh.
          Never commit it.
        </p>
      </div>
      <div class="reveal-body">
        <label class="field-hint">Raw token</label>
        <code class="raw-token" id="raw-token">{generatedToken}</code>
        <button
          type="button"
          class="btn btn-primary btn-sm"
          onclick={`navigator.clipboard.writeText(document.getElementById('raw-token').textContent || '');`}
        >
          Copy token
        </button>
      </div>

      <div class="connect-section">
        <label class="field-hint">Granted tools</label>
        <div class="tools-chips">
          {generatedTools.map((t) => (
            <code class="tool-chip">{t}</code>
          ))}
        </div>
      </div>

      <div class="connect-section">
        <label class="field-hint">Env export</label>
        <pre class="env-export" id="env-export">{`export QUERIA_AGENT_TOKEN='${generatedToken}'
export QUERIA_EDGE_URL='${publicBase}'
export QUERIA_MCP_URL='${publicBase}/mcp'${
  generatedProjectSlugs.length === 1
    ? `\nexport QUERIA_PROJECT_SLUG='${generatedProjectSlugs[0]}'`
    : ''
}`}</pre>
        <button
          type="button"
          class="btn btn-secondary btn-sm"
          onclick={`navigator.clipboard.writeText(document.getElementById('env-export').textContent || '');`}
        >
          Copy env
        </button>
      </div>

      <div class="connect-section">
        <a class="stat-link" href={`${publicBase}/api/v1/docs/agent-setup`}>
          Agent setup docs →
        </a>
        <p class="field-hint">Use setup / mcp-snippet endpoints for client commands. No paste required here.</p>
      </div>
    </div>
  )}

  <div class="tokens-split-layout">
    <!-- List of Tokens -->
    <div class="card tokens-list-panel">
      <div class="panel-header">
        <h2>Active Agent Tokens</h2>
      </div>

      {tokens.length > 0 ? (
        <div class="table-container">
          <table class="tokens-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Prefix</th>
                <th>Projects</th>
                <th>Created At</th>
                <th>Last Used At</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {tokens.map((t: any) => (
                <tr>
                  <td class="token-desc">{t.name}</td>
                  <td><code class="prefix-code">{t.token_prefix}***</code></td>
                  <td class="token-projects">
                    {Array.isArray(t.project_slugs) && t.project_slugs.length > 0
                      ? t.project_slugs.join(', ')
                      : '—'}
                  </td>
                  <td>{formatDate(t.created_at)}</td>
                  <td>{formatDate(t.last_used_at)}</td>
                  <td>
                    <form method="POST" style="display:inline" onsubmit="return confirm('Are you sure you want to revoke this agent token? This action is permanent.');">
                      <input type="hidden" name="action" value="revoke" />
                      <input type="hidden" name="token_id" value={t.id} />
                      <button type="submit" class="btn btn-secondary btn-sm btn-danger-hover">Revoke</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="empty-state">
          <p>No active agent tokens exist. Generate a new token below to configure AI clients.</p>
        </div>
      )}
    </div>

    <!-- Generate New Token -->
    <div class="card token-generate-panel">
      <div class="panel-header">
        <h2>Generate Agent Token</h2>
      </div>

      {!hasProjects ? (
        <div class="empty-state form-empty">
          <p>No projects exist yet. Create a project first, then generate an agent token scoped to it.</p>
          <a href="/admin/projects" class="btn btn-primary btn-block">Go to Projects</a>
        </div>
      ) : (
        <form method="POST">
          <input type="hidden" name="action" value="generate" />

          <div class="form-group">
            <label for="name">Token name</label>
            <input 
              type="text" 
              name="name" 
              id="name" 
              placeholder="e.g. Claude Code MCP Gateway" 
              required
              class="form-control"
            />
          </div>

          <div class="form-group">
            <label>Projects</label>
            <p class="field-hint">Select at least one project this token can access.</p>
            <div class="checkbox-list">
              {projects.map((p: any) => (
                <label class="checkbox-row">
                  <input type="checkbox" name="project_slugs" value={p.slug} />
                  <span class="checkbox-label">
                    <span class="project-name">{p.name || p.slug}</span>
                    <code class="project-slug">{p.slug}</code>
                  </span>
                </label>
              ))}
            </div>
          </div>

          <div class="form-group">
            <label class="checkbox-row single">
              <input type="checkbox" name="allow_global_knowledge" id="allow_global_knowledge" />
              <span class="checkbox-label">Allow global knowledge</span>
            </label>
          </div>

          <div class="form-group">
            <label>Mode</label>
            <div class="radio-list">
              <label class="checkbox-row single">
                <input type="radio" name="mode" value="daily" checked />
                <span class="checkbox-label">Daily agent (recommended)</span>
              </label>
              <label class="checkbox-row single">
                <input type="radio" name="mode" value="custom" id="mode-custom" />
                <span class="checkbox-label">Custom tools</span>
              </label>
            </div>
            <p class="field-hint">Daily includes retrieve, search, propose, list_projects, get_source, and index_memory. Privileged tools only via Custom.</p>
          </div>

          <div class="form-group custom-tools" id="custom-tools" hidden>
            <label>Tools</label>
            {['retrieve_context','search_knowledge','propose_memory','list_projects','get_source','index_memory'].map((t) => (
              <label class="checkbox-row">
                <input type="checkbox" name="tools" value={t} checked />
                <span class="checkbox-label"><code>{t}</code></span>
              </label>
            ))}
            <label class="checkbox-row">
              <input type="checkbox" name="tools" value="index_local" />
              <span class="checkbox-label">
                <code>index_local</code>
                <span class="field-hint warn">Uploads land in Needs review only.</span>
              </span>
            </label>
            <label class="checkbox-row">
              <input type="checkbox" name="tools" value="manage_needs_review" />
              <span class="checkbox-label">
                <code>manage_needs_review</code>
                <span class="field-hint warn">Can promote/reject Needs review items.</span>
              </span>
            </label>
          </div>

          <div class="form-group">
            <label for="expires_in">Expires in</label>
            <select name="expires_in" id="expires_in" class="form-control">
              <option value="1_day">1 day</option>
              <option value="7_days">7 days</option>
              <option value="30_days">30 days</option>
              <option value="1_year">1 year</option>
              <option value="no_expire" selected>No expiry</option>
            </select>
          </div>

          <button type="submit" class="btn btn-primary btn-block">Generate Token</button>
        </form>
        <script is:inline>
          (function () {
            const custom = document.getElementById('mode-custom');
            const box = document.getElementById('custom-tools');
            if (!custom || !box) return;
            const sync = () => {
              const isCustom = document.querySelector('input[name="mode"]:checked')?.value === 'custom';
              box.hidden = !isCustom;
            };
            document.querySelectorAll('input[name="mode"]').forEach((el) => el.addEventListener('change', sync));
            sync();
          })();
        </script>
      )}
    </div>
  </div>
</AdminLayout>

<style>
  .tokens-split-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--spacing-lg);
  }

  .tokens-list-panel, .token-generate-panel {
    padding: var(--spacing-xl);
  }

  .panel-header {
    margin-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-outline-variant);
    padding-bottom: var(--spacing-sm);
  }

  .panel-header h2 {
    font-family: var(--font-family-headline);
    font-size: 16px;
    color: var(--color-on-surface);
  }

  .alert-message {
    padding: var(--spacing-md);
    border-radius: var(--radius-sm);
    font-size: 13px;
    margin-bottom: var(--spacing-lg);
  }

  .alert-message.success {
    background-color: #0a2e1f;
    color: #34d399;
    border: 1px solid #145c40;
  }

  .alert-message.error {
    background-color: var(--color-error-container);
    color: var(--color-on-error-container);
    border: 1px solid var(--color-error);
  }

  .token-reveal-box {
    border: 1px solid var(--color-primary);
    background-color: var(--color-surface-container-high);
    box-shadow: var(--shadow-elevated);
    padding: var(--spacing-xl);
    margin-bottom: var(--spacing-lg);
  }

  .reveal-header h3 {
    font-family: var(--font-family-headline);
    color: var(--color-primary);
    font-size: 18px;
  }

  .warning-text {
    font-family: var(--font-family-caption);
    font-size: 12px;
    color: var(--color-on-surface-variant);
    margin-top: 4px;
  }

  .reveal-body {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-top: var(--spacing-md);
    background-color: var(--color-surface-container-lowest);
    border: 1px solid var(--color-outline-variant);
    padding: var(--spacing-md);
    border-radius: var(--radius-sm);
    justify-content: space-between;
  }

  .raw-token {
    font-family: var(--font-family-mono);
    font-size: 14px;
    color: var(--color-on-surface);
    word-break: break-all;
  }

  .connect-panel .connect-section {
    margin-top: var(--spacing-md);
  }

  .connect-panel .reveal-body {
    flex-wrap: wrap;
  }

  .tools-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tool-chip {
    background: var(--surface-card, #111);
    border: 1px solid var(--border-subtle, #222233);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.8rem;
  }

  .env-export {
    background: #0a0a0a;
    border: 1px solid #222233;
    padding: 0.75rem;
    overflow-x: auto;
    font-size: 0.8rem;
    margin: 0 0 var(--spacing-sm);
    color: var(--color-on-surface);
    font-family: var(--font-family-mono);
  }

  .stat-link {
    color: var(--color-primary);
    text-decoration: none;
    font-size: 13px;
  }

  .stat-link:hover {
    text-decoration: underline;
  }

  .table-container {
    overflow-x: auto;
  }

  .tokens-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-family-body);
    font-size: 13px;
    text-align: left;
  }

  .tokens-table th {
    background-color: var(--color-surface-container-high);
    color: var(--color-on-surface-variant);
    font-family: var(--font-family-caption);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--spacing-md);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .tokens-table td {
    padding: var(--spacing-md);
    border-bottom: 1px solid var(--color-outline-variant);
    color: var(--color-on-surface);
  }

  .tokens-table tbody tr:hover {
    background-color: var(--color-surface-container-high);
  }

  .token-desc {
    font-weight: 600;
  }

  .token-projects {
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-on-surface-variant);
    max-width: 160px;
    word-break: break-word;
  }

  .prefix-code {
    font-family: var(--font-family-mono);
    font-size: 11px;
    background-color: var(--color-surface-container-lowest);
    color: var(--color-on-surface);
    padding: 0.125rem 0.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-outline-variant);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-lg);
  }

  .form-group label {
    font-family: var(--font-family-caption);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-on-surface-variant);
  }

  .field-hint {
    font-family: var(--font-family-caption);
    font-size: 11px;
    color: var(--color-on-surface-variant);
    margin: 0 0 4px;
    text-transform: none;
    font-weight: 400;
    letter-spacing: normal;
  }

  .field-hint.warn {
    color: var(--color-warning, #f0a000);
    display: block;
    margin-top: 0.25rem;
  }

  .radio-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .checkbox-row input[type="radio"] {
    margin-top: 2px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  .custom-tools {
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-sm);
    padding: var(--spacing-sm);
    background-color: var(--color-surface-container-lowest);
  }

  .form-control {
    width: 100%;
    padding: 0.5rem var(--spacing-md);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-default);
    background-color: var(--color-surface-container-lowest);
    color: var(--color-on-surface);
    font-family: var(--font-family-body);
    font-size: 13px;
    outline: none;
  }

  .form-control:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary);
  }

  select.form-control {
    appearance: auto;
    cursor: pointer;
  }

  .checkbox-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 200px;
    overflow-y: auto;
    padding: var(--spacing-sm);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-sm);
    background-color: var(--color-surface-container-lowest);
  }

  .checkbox-row {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-family: var(--font-family-body);
    font-size: 13px;
    font-weight: 400;
    text-transform: none;
    letter-spacing: normal;
    color: var(--color-on-surface);
    cursor: pointer;
  }

  .checkbox-row.single {
    text-transform: none;
    font-weight: 400;
    letter-spacing: normal;
  }

  .checkbox-row input[type="checkbox"] {
    margin-top: 2px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  .checkbox-label {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .project-name {
    color: var(--color-on-surface);
  }

  .project-slug {
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-on-surface-variant);
  }

  .btn-block {
    width: 100%;
  }

  .btn-sm {
    padding: 0.25rem 0.5rem;
    font-size: 11px;
  }

  .btn-danger-hover:hover {
    border-color: var(--color-error);
    color: var(--color-error);
    background-color: var(--color-error-container);
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-xxl);
    color: var(--color-on-surface-variant);
    font-style: italic;
  }

  .form-empty {
    padding: var(--spacing-lg) 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    font-style: normal;
  }

  .form-empty p {
    font-style: italic;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .tokens-split-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
