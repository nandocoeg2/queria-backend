---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listProjects, createProject } from '../../lib/api';

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const slug = data.get('slug')?.toString() || '';
    const name = data.get('name')?.toString() || '';
    const description = data.get('description')?.toString() || undefined;
    const default_embedding_model = data.get('default_embedding_model')?.toString() || undefined;
    const include_global_default = data.get('include_global_default') === 'true';

    const res = await createProject(Astro.request, {
      slug,
      name,
      description,
      default_embedding_model,
      include_global_default,
    });

    if (res.ok) {
      return Astro.redirect('/admin/projects');
    } else {
      const errData = await res.json().catch(() => ({}));
      error = errData.error || 'Failed to create project';
    }
  } catch (err) {
    console.error('Create project error:', err);
    error = 'Failed to connect to backend server';
  }
}

const projects = await listProjects(Astro.request);
if (!projects) {
  return Astro.redirect('/admin/login');
}

// Format dates nicely
const formatDate = (dateStr?: string) => {
  if (!dateStr) return 'N/A';
  return new Date(dateStr).toLocaleString('en-US', {
    dateStyle: 'medium',
  });
};
---

<AdminLayout title="Projects Management" activeTab="projects">
  {error && (
    <div class="alert-message error">
      <strong>Error:</strong> {error}
    </div>
  )}

  <div class="card projects-panel">
    <div class="panel-header">
      <h2>Registered Projects</h2>
      <button type="button" class="btn btn-primary" onclick="document.getElementById('create-project-dialog').showModal()">
        Create Project
      </button>
    </div>

    {projects.length > 0 ? (
      <div class="table-container">
        <table class="projects-table">
          <thead>
            <tr>
              <th>Slug</th>
              <th>Name</th>
              <th>Description</th>
              <th>Default Model</th>
              <th>Global Default</th>
              <th>Created At</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {projects.map((project: any) => (
              <tr>
                <td><code class="project-slug">{project.slug}</code></td>
                <td class="project-name">{project.name}</td>
                <td class="project-desc">{project.description || <span class="muted">—</span>}</td>
                <td><code class="model-code">{project.default_embedding_model}</code></td>
                <td>
                  <span class={`badge ${project.include_global_default ? 'badge-approved' : 'badge-stale'}`}>
                    {project.include_global_default ? 'Enabled' : 'Disabled'}
                  </span>
                </td>
                <td>{formatDate(project.created_at)}</td>
                <td class="action-cell">
                  <a href={`/admin/sources?project_slug=${project.slug}`} class="btn btn-secondary btn-sm">
                    Manage Sources
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state">
        <p>No projects registered in this organization.</p>
      </div>
    )}
  </div>

  <!-- Create Project Dialog Modal (tokenized Violet Void) -->
  <dialog id="create-project-dialog" class="create-dialog">
    <div class="dialog-header">
      <h3>Create New Project</h3>
      <button type="button" class="dialog-close" onclick="document.getElementById('create-project-dialog').close()" aria-label="Close">✕</button>
    </div>

    <form method="POST" class="dialog-form">
      <div class="field">
        <label for="slug">Project slug</label>
        <input
          type="text"
          id="slug"
          name="slug"
          required
          placeholder="e.g. my-awesome-project"
          pattern="[a-z0-9-]{3,64}"
          title="Slug must be lowercase alphanumeric and dashes only, 3-64 chars."
        />
      </div>

      <div class="field">
        <label for="name">Project name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="e.g. My Awesome Project"
          maxlength="128"
        />
      </div>

      <div class="field">
        <label for="description">Description</label>
        <textarea
          id="description"
          name="description"
          placeholder="Describe your project..."
          rows="3"
        ></textarea>
      </div>

      <div class="field">
        <label for="default_embedding_model">Default embedding model</label>
        <select id="default_embedding_model" name="default_embedding_model">
          <option value="voyage-4" selected>Voyage 4 (voyage-4)</option>
          <option value="voyage-code-3">Voyage Code 3 (voyage-code-3)</option>
        </select>
      </div>

      <div class="field-check">
        <input
          type="checkbox"
          id="include_global_default"
          name="include_global_default"
          value="true"
          checked
        />
        <label for="include_global_default">Include global knowledge by default</label>
      </div>

      <div class="dialog-actions">
        <button
          type="button"
          class="btn btn-secondary"
          onclick="document.getElementById('create-project-dialog').close()"
        >
          Cancel
        </button>
        <button type="submit" class="btn btn-primary">
          Create Project
        </button>
      </div>
    </form>
  </dialog>
</AdminLayout>

<style>
  .alert-message {
    padding: var(--spacing-md);
    border-radius: var(--radius-sm);
    font-size: 13px;
    margin-bottom: var(--spacing-lg);
  }

  .alert-message.error {
    background-color: var(--color-error-container);
    color: var(--color-on-error-container);
    border: 1px solid var(--color-error);
  }

  .projects-panel {
    padding: var(--spacing-xl);
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-outline-variant);
    padding-bottom: var(--spacing-sm);
  }

  .panel-header h2 {
    font-size: 16px;
    color: var(--color-on-surface);
    font-family: var(--font-family-headline);
  }

  .table-container {
    overflow-x: auto;
  }

  .projects-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-family-body);
    font-size: 13px;
    text-align: left;
  }

  .projects-table th {
    background-color: var(--color-surface-container-high);
    color: var(--color-on-surface-variant);
    font-family: var(--font-family-caption);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--spacing-md);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .projects-table td {
    padding: var(--spacing-md);
    border-bottom: 1px solid var(--color-outline-variant);
    color: var(--color-on-surface);
  }

  .projects-table tbody tr:hover {
    background-color: var(--color-surface-container-high);
  }

  .project-slug {
    font-family: var(--font-family-mono);
    font-size: 11px;
    background-color: var(--color-surface-container-lowest);
    color: var(--color-on-surface);
    padding: 0.125rem 0.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-outline-variant);
  }

  .project-name {
    font-weight: 600;
  }

  .project-desc {
    max-width: 250px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .model-code {
    font-family: var(--font-family-mono);
    font-size: 11px;
    color: var(--color-on-surface-variant);
  }

  .muted {
    color: var(--color-on-surface-variant);
  }

  .action-cell {
    display: flex;
    gap: var(--spacing-sm);
  }

  .btn-sm {
    padding: 0.25rem 0.5rem;
    font-size: 11px;
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-xxl);
    color: var(--color-on-surface-variant);
    font-style: italic;
  }

  /* Dark create dialog */
  .create-dialog {
    max-width: 28rem;
    width: calc(100% - 2rem);
    margin: auto;
    padding: var(--spacing-xl);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
    box-shadow: var(--shadow-elevated);
  }

  .create-dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.65);
  }

  .dialog-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .dialog-header h3 {
    font-size: 1.125rem;
    font-family: var(--font-family-headline);
    font-weight: 600;
    color: var(--color-on-surface);
  }

  .dialog-close {
    background: transparent;
    border: none;
    color: var(--color-on-surface-variant);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
  }

  .dialog-close:hover {
    color: var(--color-primary);
  }

  .dialog-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .field label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-on-surface-variant);
    font-family: var(--font-family-caption);
  }

  .field input,
  .field textarea,
  .field select {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-sm);
    background-color: var(--color-surface-container-lowest);
    color: var(--color-on-surface);
    font-family: var(--font-family-body);
    font-size: 13px;
    outline: none;
  }

  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary);
  }

  .field textarea {
    resize: none;
  }

  .field select {
    appearance: auto;
  }

  .field-check {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.25rem;
  }

  .field-check input[type="checkbox"] {
    accent-color: var(--color-primary);
    width: 1rem;
    height: 1rem;
  }

  .field-check label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-on-surface);
  }

  .dialog-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    padding-top: var(--spacing-md);
    margin-top: var(--spacing-sm);
    border-top: 1px solid var(--color-outline-variant);
  }
</style>
