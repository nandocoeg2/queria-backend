---
import '../styles/tokens.css';

let error = '';

// Handle setup POST request
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const organizationName = data.get('organization_name');
    const organizationSlug = data.get('organization_slug');
    const adminName = data.get('admin_name');
    const adminEmail = data.get('admin_email');
    const adminPassword = data.get('admin_password');
    const seedProject = data.get('seed_project') === 'true';

    const backendUrl = import.meta.env.QUERIA_API_URL || process.env.QUERIA_API_URL || 'http://localhost:17671';
    
    const response = await fetch(`${backendUrl}/api/v1/setup`, {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
      },
      body: JSON.stringify({
        organization_name: organizationName,
        organization_slug: organizationSlug,
        admin_name: adminName,
        admin_email: adminEmail,
        admin_password: adminPassword,
        seed_project: seedProject,
      }),
    });

    if (response.ok) {
      const result = await response.json();
      if (result.success) {
        // Automatically sign in the user after setup by setting the session cookie
        const setCookieHeader = response.headers.get('set-cookie');
        const headers = new Headers();
        headers.set('Location', '/admin');
        if (setCookieHeader) {
          headers.set('Set-Cookie', setCookieHeader);
        }
        return new Response(null, {
          status: 302,
          headers,
        });
      } else {
        error = result.error || 'Setup failed';
      }
    } else {
      const errRes = await response.json().catch(() => ({}));
      error = errRes.error || 'Failed to complete setup.';
    }
  } catch (err) {
    console.error('Setup submission error:', err);
    error = 'Failed to communicate with setup server.';
  }
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>First-Run Setup Wizard | Queria</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400..800&family=Manrope:wght@400..800&display=swap" rel="stylesheet">
  </head>
  <body class="setup-body">
    <div class="setup-container">
      <div class="setup-header">
        <div class="logo">Q</div>
        <h1>Queria</h1>
        <p>First-Run Infrastructure Setup Wizard</p>
      </div>

      <div class="card setup-card">
        {error && <div class="error-alert">{error}</div>}

        <form method="POST">
          <div class="section-title">
            <h3>1. Organization Details</h3>
          </div>
          
          <div class="form-group">
            <label for="organization_name">Organization Name</label>
            <input 
              type="text" 
              id="organization_name" 
              name="organization_name" 
              required 
              placeholder="Fernando Julian Organization" 
              class="form-control"
            />
          </div>

          <div class="form-group">
            <label for="organization_slug">Organization Slug</label>
            <input 
              type="text" 
              id="organization_slug" 
              name="organization_slug" 
              required 
              placeholder="fjulian" 
              class="form-control"
            />
          </div>

          <div class="section-title">
            <h3>2. Admin Account Credentials</h3>
          </div>

          <div class="form-group">
            <label for="admin_name">Full Name</label>
            <input 
              type="text" 
              id="admin_name" 
              name="admin_name" 
              required 
              placeholder="Nando Julian" 
              class="form-control"
            />
          </div>

          <div class="form-group">
            <label for="admin_email">Email Address</label>
            <input 
              type="email" 
              id="admin_email" 
              name="admin_email" 
              required 
              placeholder="nando@fjulian.id" 
              class="form-control"
            />
          </div>

          <div class="form-group">
            <label for="admin_password">Password</label>
            <input 
              type="password" 
              id="admin_password" 
              name="admin_password" 
              required 
              placeholder="At least 8 characters" 
              minlength="8"
              class="form-control"
            />
          </div>

          <div class="section-title">
            <h3>3. Project Seeding</h3>
          </div>

          <div class="form-group checkbox-group">
            <input 
              type="checkbox" 
              id="seed_project" 
              name="seed_project" 
              value="true" 
              checked
            />
            <label for="seed_project">Seed default project <code>fjulian-me</code></label>
          </div>

          <button type="submit" class="btn btn-primary btn-block">Complete System Setup</button>
        </form>
      </div>
    </div>
  </body>
</html>

<style>
