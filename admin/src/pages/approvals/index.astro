---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listApprovals, fetchFromBackend } from '../../lib/api';

let message = '';
let isError = false;

// Handle approve / reject actions
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action');
    const approvalId = data.get('approval_id');

    if (approvalId && (action === 'approve' || action === 'reject')) {
      const endpoint = `/api/v1/approvals/${approvalId}/${action}`;
      const res = await fetchFromBackend(endpoint, Astro.request, {
        method: 'POST',
      });

      if (res.ok) {
        message = `Proposal successfully ${action === 'approve' ? 'approved' : 'rejected'}.`;
      } else {
        const errorRes = await res.json().catch(() => ({}));
        message = errorRes.error || `Failed to ${action} proposal.`;
        isError = true;
      }
    }
  } catch (err) {
    console.error('Approval action error:', err);
    message = 'Error communicating with server.';
    isError = true;
  }
}

const approvals = await listApprovals(Astro.request);
if (!approvals) {
  return Astro.redirect('/admin/login');
}

// Format dates nicely
const formatDate = (dateStr?: string) => {
  if (!dateStr) return 'N/A';
  return new Date(dateStr).toLocaleString('en-US', {
    dateStyle: 'medium',
    timeStyle: 'short',
  });
};
---

<AdminLayout title="Approvals Queue" activeTab="approvals">
  {message && (
    <div class={`alert-message ${isError ? 'error' : 'success'}`}>
      {message}
    </div>
  )}

  <div class="card approvals-panel">
    <div class="panel-header">
      <h2>Proposed Knowledge Items</h2>
    </div>

    {approvals.length > 0 ? (
      <div class="table-container">
        <table class="approvals-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Category</th>
              <th>Proposed By</th>
              <th>Source / Scope</th>
              <th>Proposed At</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {approvals.map((approval: any) => (
              <tr>
                <td>
                  <div class="proposal-title">{approval.title}</div>
                  <pre class="proposal-body"><code>{approval.body}</code></pre>
                </td>
                <td class="cat-cell">{approval.category}</td>
                <td><code class="actor-code">{approval.proposed_by}</code></td>
                <td>
                  <span class="scope-cell">{approval.scope}</span>
                  {approval.source_document_id && (
                    <a href={`/admin/sources/detail?id=${approval.source_document_id}`} class="source-link">
                      source document
                    </a>
                  )}
                </td>
                <td>{formatDate(approval.created_at)}</td>
                <td class="action-cell">
                  <button
                    type="button"
                    class="btn btn-primary btn-sm"
                    data-open-confirm="approve"
                    data-approval-id={approval.id}
                    data-approval-title={approval.title || 'Untitled proposal'}
                  >
                    Approve
                  </button>
                  <button
                    type="button"
                    class="btn btn-secondary btn-sm btn-danger-hover"
                    data-open-confirm="reject"
                    data-approval-id={approval.id}
                    data-approval-title={approval.title || 'Untitled proposal'}
                  >
                    Reject
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state">
        <p>No pending proposals in the queue.</p>
      </div>
    )}
  </div>

  <!-- Approve confirmation (SSR POST; dark Violet Void dialog) -->
  <dialog id="approve-confirm-dialog" class="confirm-dialog">
    <div class="dialog-header">
      <h3>Approve proposal</h3>
      <button type="button" class="dialog-close" data-close-dialog="approve-confirm-dialog" aria-label="Close">✕</button>
    </div>
    <p class="dialog-body">
      Confirm approval of <strong id="approve-confirm-title">this proposal</strong>? Approved items join the knowledge base.
    </p>
    <form method="POST" class="dialog-form">
      <input type="hidden" name="action" value="approve" />
      <input type="hidden" name="approval_id" id="approve-confirm-id" value="" />
      <div class="dialog-actions">
        <button type="button" class="btn btn-secondary" data-close-dialog="approve-confirm-dialog">
          Cancel
        </button>
        <button type="submit" class="btn btn-primary">
          Confirm Approve
        </button>
      </div>
    </form>
  </dialog>

  <!-- Reject confirmation (SSR POST; distinct destructive confirm) -->
  <dialog id="reject-confirm-dialog" class="confirm-dialog">
    <div class="dialog-header">
      <h3>Reject proposal</h3>
      <button type="button" class="dialog-close" data-close-dialog="reject-confirm-dialog" aria-label="Close">✕</button>
    </div>
    <p class="dialog-body">
      Confirm rejection of <strong id="reject-confirm-title">this proposal</strong>? It will leave the pending queue without being published.
    </p>
    <form method="POST" class="dialog-form">
      <input type="hidden" name="action" value="reject" />
      <input type="hidden" name="approval_id" id="reject-confirm-id" value="" />
      <div class="dialog-actions">
        <button type="button" class="btn btn-secondary" data-close-dialog="reject-confirm-dialog">
          Cancel
        </button>
        <button type="submit" class="btn btn-secondary btn-danger-confirm">
          Confirm Reject
        </button>
      </div>
    </form>
  </dialog>

  <script is:inline>
    (function () {
      function openConfirm(kind, id, title) {
        const dialog = document.getElementById(kind === 'approve' ? 'approve-confirm-dialog' : 'reject-confirm-dialog');
        const idInput = document.getElementById(kind === 'approve' ? 'approve-confirm-id' : 'reject-confirm-id');
        const titleEl = document.getElementById(kind === 'approve' ? 'approve-confirm-title' : 'reject-confirm-title');
        if (!dialog || !idInput || !titleEl) return;
        idInput.value = id || '';
        titleEl.textContent = title || 'this proposal';
        if (typeof dialog.showModal === 'function') {
          dialog.showModal();
        }
      }

      document.querySelectorAll('[data-open-confirm]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          openConfirm(
            btn.getAttribute('data-open-confirm'),
            btn.getAttribute('data-approval-id'),
            btn.getAttribute('data-approval-title')
          );
        });
      });

      document.querySelectorAll('[data-close-dialog]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const dialog = document.getElementById(btn.getAttribute('data-close-dialog'));
          if (dialog && typeof dialog.close === 'function') dialog.close();
        });
      });
    })();
  </script>
</AdminLayout>

<style>
  .approvals-panel {
    padding: var(--spacing-xl);
  }

  .panel-header {
    margin-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-outline-variant);
    padding-bottom: var(--spacing-sm);
  }

  .panel-header h2 {
    font-family: var(--font-family-headline);
    font-size: 16px;
    color: var(--color-on-surface);
  }

  .alert-message {
    padding: var(--spacing-md);
    border-radius: var(--radius-sm);
    font-size: 13px;
    margin-bottom: var(--spacing-lg);
  }

  .alert-message.success {
    background-color: #0a2e1f;
    color: #34d399;
    border: 1px solid #145c40;
  }

  .alert-message.error {
    background-color: var(--color-error-container);
    color: var(--color-on-error-container);
    border: 1px solid var(--color-error);
  }

  .table-container {
    overflow-x: auto;
  }

  .approvals-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-family-body);
    font-size: 13px;
    text-align: left;
  }

  .approvals-table th {
    background-color: var(--color-surface-container-high);
    color: var(--color-on-surface-variant);
    font-family: var(--font-family-caption);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--spacing-md);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .approvals-table td {
    padding: var(--spacing-md);
    border-bottom: 1px solid var(--color-outline-variant);
    color: var(--color-on-surface);
    vertical-align: top;
  }

  .approvals-table tbody tr:hover {
    background-color: var(--color-surface-container-high);
  }

  .proposal-title {
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
    color: var(--color-on-surface);
  }

  .proposal-body {
    background-color: var(--color-surface-container-lowest);
    border: 1px solid var(--color-outline-variant);
    padding: var(--spacing-sm);
    border-radius: var(--radius-sm);
    max-width: 400px;
    max-height: 120px;
    overflow-y: auto;
    font-size: 11px;
    color: var(--color-on-surface-variant);
    white-space: pre-wrap;
    word-break: break-all;
  }

  .cat-cell {
    font-weight: 500;
  }

  .actor-code {
    font-family: var(--font-family-mono);
    font-size: 11px;
    background-color: var(--color-surface-container-lowest);
    color: var(--color-on-surface);
    padding: 0.125rem 0.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-outline-variant);
  }

  .scope-cell {
    display: block;
    font-family: var(--font-family-caption);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
  }

  .source-link {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-primary);
  }

  .source-link:hover {
    color: var(--color-primary-container);
  }

  .action-cell {
    display: flex;
    gap: var(--spacing-sm);
  }

  .btn-sm {
    padding: 0.25rem 0.5rem;
    font-size: 11px;
  }

  .btn-danger-hover:hover {
    border-color: var(--color-error);
    color: var(--color-error);
    background-color: var(--color-error-container);
  }

  .btn-danger-confirm {
    border-color: var(--color-error);
    color: var(--color-error);
    background-color: var(--color-error-container);
  }

  .btn-danger-confirm:hover {
    background-color: color-mix(in srgb, var(--color-error) 22%, transparent);
    color: #fff;
    border-color: var(--color-error);
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-xxl);
    color: var(--color-on-surface-variant);
    font-style: italic;
  }

  /* Confirm dialogs — dark elevated panels (match projects create dialog) */
  .confirm-dialog {
    max-width: 26rem;
    width: calc(100% - 2rem);
    margin: auto;
    padding: var(--spacing-xl);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
    box-shadow: var(--shadow-elevated);
  }

  .confirm-dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.65);
  }

  .dialog-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .dialog-header h3 {
    font-size: 1.125rem;
    font-family: var(--font-family-headline);
    font-weight: 600;
    color: var(--color-on-surface);
  }

  .dialog-close {
    background: transparent;
    border: none;
    color: var(--color-on-surface-variant);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
  }

  .dialog-close:hover {
    color: var(--color-primary);
  }

  .dialog-body {
    font-family: var(--font-family-body);
    font-size: 13px;
    color: var(--color-on-surface-variant);
    line-height: 1.5;
    margin: 0 0 var(--spacing-lg);
  }

  .dialog-body strong {
    color: var(--color-on-surface);
    font-weight: 600;
  }

  .dialog-form {
    display: flex;
    flex-direction: column;
  }

  .dialog-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-outline-variant);
  }
</style>
